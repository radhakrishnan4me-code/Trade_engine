# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/trade_engine
DATABASE_URL_SYNC=postgresql://postgres:postgres@postgres:5432/trade_engine

# Security
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
JWT_SECRET=change-me-jwt-secret-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=*

# Default admin user (created on first startup)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=trade_engine
